pipeline {
    agent any

    stages {
        stage('Verify Docker') {
            steps {
                bat 'where docker'
                bat 'docker version'
            }
        }

        stage('Stop and Remove Old Container') {
            steps {
                bat 'docker container stop dmanC || echo no container to stop'
                bat 'docker container rm dmanC || echo no container to remove'
            }
        }

        stage('Remove Old Image') {
            steps {
                bat 'docker image rm dmanI || echo no image to remove'
            }
        }

        stage('Build Docker Image') {
            steps {
                bat 'docker build -t dmanI .'
            }
        }

        stage('Run Container') {
            steps {
                bat 'docker run -d -p 2222:80 --name dmanC dmanI'
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully.'
        }
        failure {
            echo 'Pipeline failed.'
        }
        always {
            echo 'Pipeline execution finished.'
        }
    }
}